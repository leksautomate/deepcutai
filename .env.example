# DeepCut AI - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=5000

# Admin Account (required for first login)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password

# Session Security
SESSION_SECRET=generate_a_random_64_character_string_here
COOKIE_SECURE=false

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/deepcut

# AI Services (configure in Settings page or here)
# GEMINI_API_KEY=your_gemini_api_key
# GROQ_API_KEY=your_groq_api_key

# TTS Services
# SPEECHIFY_API_KEY=your_speechify_api_key
# INWORLD_API_KEY=your_inworld_api_key

# Image Generation Services
# FREEPIK_API_KEY=your_freepik_seedream_api_key
# WAVESPEED_API_KEY=your_wavespeed_api_key
# RUNPOD_API_KEY=your_runpod_api_key
# POLLINATIONS_API_KEY=your_pollinations_api_key
