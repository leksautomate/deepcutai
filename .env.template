# DeepCut AI - Environment Configuration Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env:
#    cp .env.template .env
# 2. Update values as needed. Most defaults work for local development.
# ==============================================================================

# ------------------------------
# SERVER CONFIGURATION
# ------------------------------
# Environment: 'development' (local) or 'production' (server)
NODE_ENV=development

# Server Port (default: 5000)
PORT=5000

# Server Host (0.0.0.0 exposes to network, localhost limits to local)
HOST=0.0.0.0

# ------------------------------
# DATABASE CONFIGURATION
# ------------------------------
# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://deepcut:local_password@localhost:5432/deepcut

# ------------------------------
# AUTHENTICATION & SECURITY
# ------------------------------
# Session Secret: Used to sign session cookies. 
# Generate secure random string for production: `openssl rand -hex 32`
SESSION_SECRET=dev_session_secret_change_me_in_production

# Cookie Security: Set to 'true' if serving over HTTPS
COOKIE_SECURE=false

# ------------------------------
# ADMIN ACCOUNT (Optional)
# ------------------------------
# If set, these credentials are used to create/update the admin account on startup.
# If unset, you must create an admin account via the web UI first setup.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# ADMIN_EMAIL=admin@example.com

# ------------------------------
# EXTERNAL API KEYS
# ------------------------------
# Note: Keys can also be configured via the Web UI Settings page.
# Docker secrets (in /run/secrets/) take precedence over these variables.

# --- Script Generation ---
# Google Gemini (Free tier available)
GEMINI_API_KEY=
# Groq (Llama 3, Mixtral)
GROQ_API_KEY=

# --- Text-to-Speech ---
# Speechify
SPEECHIFY_API_KEY=
# Inworld AI
INWORLD_API_KEY=

# --- Image Generation ---
# Freepik / Seedream
FREEPIK_API_KEY=
# WaveSpeed.ai (Stable Diffusion Turbo)
WAVESPEED_API_KEY=
# RunPod (Custom Models)
RUNPOD_API_KEY=
# Pollinations.ai (Optional, free tier has limits)
POLLINATIONS_API_KEY=
